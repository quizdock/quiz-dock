    "clsx": "^2.1.1",
    "i18next": "^26.3.1",
    "lucide-react": "^1.17.0",
    "oidc-client-ts": "^3.5.0",
    "qrcode.react": "^4.2.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-i18next": "^17.0.8",
    "socket.io-client": "^4.8.3",
    "tailwind-merge": "^3.6.0",
