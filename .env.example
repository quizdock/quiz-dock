# Copier en `.env` et adapter. Ne jamais committer le `.env` réel.

# --- Marque (white-label) ---
# Nom d'app affiché (header, onglet, partage). Surchargé au runtime sans rebuild.
# Logo + CSS d'override : voir le dossier `branding/` (monté en volume).
APP_NAME=Live-Quizz

# --- Auth ---
# none = mode local sans IdP (dev/démo) | oidc = validation JWT d'un fournisseur OIDC
AUTH_MODE=none

# --- OIDC (utilisé seulement si AUTH_MODE=oidc) ---
# Compatible avec n'importe quel fournisseur OIDC ; Keycloak fourni en référence (dev).
# issuer = `iss` attendu (host vu par le navigateur) ; JWKS_URI peut viser un host interne (Docker).
OIDC_ISSUER=http://localhost:48080/realms/live-quizz
OIDC_JWKS_URI=http://keycloak:8080/realms/live-quizz/protocol/openid-connect/certs
# client_id public de la SPA (exposé par GET /auth/config au front).
OIDC_CLIENT_ID=live-quizz-frontend
# Optionnels : audience attendue, et chemin du claim de rôles (défaut realm_access.roles).
OIDC_AUDIENCE=
OIDC_ROLES_CLAIM=realm_access.roles

# --- Ports exposés (hôte) — peu courants pour éviter les collisions ---
# Mnémo : « 4 » + le port usuel. Ports internes des conteneurs inchangés.
BACKEND_PORT=13000
FRONTEND_PORT=18081
VITE_PORT=15173
POSTGRES_PORT=15432
REDIS_PORT=16379
KEYCLOAK_PORT=18080

# --- PostgreSQL ---
POSTGRES_USER=live
POSTGRES_PASSWORD=live
POSTGRES_DB=livequizz

# --- Médias (volume local servi par le backend) ---
# Taille maximale d'un fichier uploadé (octets). Défaut 10 Mio.
MEDIA_MAX_BYTES=10485760

# --- Keycloak, IdP OIDC de référence (démarré avec --profile keycloak) ---
# Identifiants admin de la console Keycloak. Tout autre IdP OIDC peut le remplacer
# (il suffit d'ajuster les variables OIDC_* ci-dessus).
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin
