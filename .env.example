# Copier en `.env` et adapter. Ne jamais committer le `.env` réel.

# --- Auth ---
# none = mode local sans Keycloak (dev/démo) | keycloak = OIDC complet
AUTH_MODE=none

# --- Ports exposés (hôte) ---
BACKEND_PORT=3000
FRONTEND_PORT=8081
STORAGE_S3_PORT=8333
KEYCLOAK_PORT=8080

# --- PostgreSQL ---
POSTGRES_USER=roux
POSTGRES_PASSWORD=roux
POSTGRES_DB=rouxquizz

# --- Keycloak (utilisé seulement avec --profile keycloak) ---
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin
KEYCLOAK_URL=http://keycloak:8080
